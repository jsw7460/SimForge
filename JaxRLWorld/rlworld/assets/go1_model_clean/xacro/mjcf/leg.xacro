<?xml version="1.0"?>

<mujoco xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:macro name="leg" params="name mirror mirror_dae front_hind front_hind_dae">

        <xacro:if value="${(mirror_dae == False) and (front_hind_dae == True)}">
            <xacro:property name="used_leg_offset_x" value="${leg_offset_x}"/>
            <xacro:property name="used_leg_offset_y" value="${-leg_offset_y}"/>
            <xacro:property name="used_hip_rotor_offset_x" value="${hip_rotor_offset_x}"/>
            <xacro:property name="used_hip_rotor_offset_y" value="${-hip_rotor_offset_y}"/>
        </xacro:if>
        <xacro:if value="${(mirror_dae == True) and (front_hind_dae == True)}">
            <xacro:property name="used_leg_offset_x" value="${leg_offset_x}"/>
            <xacro:property name="used_leg_offset_y" value="${leg_offset_y}"/>
            <xacro:property name="used_hip_rotor_offset_x" value="${hip_rotor_offset_x}"/>
            <xacro:property name="used_hip_rotor_offset_y" value="${hip_rotor_offset_y}"/>
        </xacro:if>
        <xacro:if value="${(mirror_dae == False) and (front_hind_dae == False)}">
            <xacro:property name="used_leg_offset_x" value="${-leg_offset_x}"/>
            <xacro:property name="used_leg_offset_y" value="${-leg_offset_y}"/>
            <xacro:property name="used_hip_rotor_offset_x" value="${-hip_rotor_offset_x}"/>
            <xacro:property name="used_hip_rotor_offset_y" value="${-hip_rotor_offset_y}"/>
        </xacro:if>
        <xacro:if value="${(mirror_dae == True) and (front_hind_dae == False)}">
            <xacro:property name="used_leg_offset_x" value="${-leg_offset_x}"/>
            <xacro:property name="used_leg_offset_y" value="${leg_offset_y}"/>
            <xacro:property name="used_hip_rotor_offset_x" value="${-hip_rotor_offset_x}"/>
            <xacro:property name="used_hip_rotor_offset_y" value="${hip_rotor_offset_y}"/>
        </xacro:if>

        <body name="${name}_hip" pos="${used_leg_offset_x} ${used_leg_offset_y} 0">
            <xacro:if value="${(mirror_dae == True)}">
                <xacro:property name="used_hip_pos_lower" value="${hip_position_min}"/>
                <xacro:property name="used_hip_pos_upper" value="${hip_position_max}"/>
            </xacro:if>
            <xacro:if value="${(mirror_dae == False)}">
                <xacro:property name="used_hip_pos_lower" value="${-hip_position_max}"/>
                <xacro:property name="used_hip_pos_upper" value="${-hip_position_min}"/>
            </xacro:if>

            <xacro:if value="${(mirror_dae == True) and (front_hind_dae == True)}">
                <xacro:property name="used_hip_visgeom_roll" value="0"/>
                <xacro:property name="used_hip_visgeom_pitch" value="0"/>
            </xacro:if>
            <xacro:if value="${(mirror_dae == False) and (front_hind_dae == True)}">
                <xacro:property name="used_hip_visgeom_roll" value="${PI}"/>
                <xacro:property name="used_hip_visgeom_pitch" value="0"/>
            </xacro:if>
            <xacro:if value="${(mirror_dae == True) and (front_hind_dae == False)}">
                <xacro:property name="used_hip_visgeom_roll" value="0"/>
                <xacro:property name="used_hip_visgeom_pitch" value="${PI}"/>
            </xacro:if>
            <xacro:if value="${(mirror_dae == False) and (front_hind_dae == False)}">
                <xacro:property name="used_hip_visgeom_roll" value="${PI}"/>
                <xacro:property name="used_hip_visgeom_pitch" value="${PI}"/>
            </xacro:if>
            
            <inertial pos="${hip_com_x*front_hind} ${hip_com_y*mirror} ${hip_com_z}" mass="${hip_mass}" fullinertia="${hip_ixx} ${hip_iyy} ${hip_izz} ${hip_ixy*mirror*front_hind} ${hip_ixz*front_hind} ${hip_iyz*mirror}"/>
            <joint name="${name}_hip_joint" type="hinge" pos="0 0 0" axis="1 0 0" range="${used_hip_pos_lower} ${used_hip_pos_upper}" actuatorfrcrange="${-hip_torque_max} ${hip_torque_max}" damping="${damping}" frictionloss="${friction}" armature="${armature}"/>
            <geom class="visual" type="mesh" mesh="hip" pos="0 0 0" euler="${used_hip_visgeom_roll} ${used_hip_visgeom_pitch} 0"/>
            <geom class="collision" type="cylinder" size="${hip_radius} ${hip_length/2.0}" pos="0 ${hip_offset*mirror} 0" euler="${PI/2.0} 0 0"/>
            <body name="${name}_thigh" pos="0 ${thigh_offset*mirror} 0">
                <xacro:if value="${mirror_dae == True}">
                    <xacro:property name="used_thigh_mesh" value="thigh"/>
                </xacro:if>
                <xacro:if value="${mirror_dae == False}">
                    <xacro:property name="used_thigh_mesh" value="thigh_mirror"/>
                </xacro:if>
                
                <inertial pos="${thigh_com_x} ${thigh_com_y*mirror} ${thigh_com_z}" mass="${thigh_mass}" fullinertia="${thigh_ixx} ${thigh_iyy} ${thigh_izz} ${thigh_ixy*mirror} ${thigh_ixz} ${thigh_iyz*mirror}"/>
                <joint name="${name}_thigh_joint" type="hinge" pos="0 0 0" axis="0 1 0" range="${thigh_position_min} ${thigh_position_max}" actuatorfrcrange="${-thigh_torque_max} ${thigh_torque_max}" damping="${damping}" frictionloss="${friction}" armature="${armature}"/>
                <geom class="visual" type="mesh" mesh="${used_thigh_mesh}" pos="0 0 0" euler="0 0 0"/>
                <geom class="collision" type="box" size="${thigh_length/2.0} ${thigh_width/2.0} ${thigh_height/2.0}" pos="0 0 ${-thigh_length/2.0}" euler="0 ${PI/2.0} 0"/>
                <body name="${name}_calf" pos="0 0 ${-thigh_length}">
                    <inertial pos="${calf_com_x} ${calf_com_y} ${calf_com_z}" mass="${calf_mass}" fullinertia="${calf_ixx} ${calf_iyy} ${calf_izz} ${calf_ixy} ${calf_ixz} ${calf_iyz}"/>
                    <joint name="${name}_calf_joint" type="hinge" pos="0 0 0" axis="0 1 0" range="${calf_position_min} ${calf_position_max}" actuatorfrcrange="${-calf_torque_max} ${calf_torque_max}" damping="${damping}" frictionloss="${friction}" armature="${armature}"/>
                    <geom class="visual" type="mesh" mesh="calf" pos="0 0 0" euler="0 0 0"/>
                    <geom class="collision" type="box" size="${calf_length/2.0} ${calf_width/2.0} ${calf_height/2.0}" pos="0 0 ${-calf_length/2.0}" euler="0 ${PI/2.0} 0"/>
                    <body name="${name}_foot" pos="0 0 ${-(calf_length)}">
                        <xacro:property name="foot_principal_inertia" value="${(2*foot_mass)/5.0*(foot_radius*foot_radius)}"/>

                        <inertial pos="0 0 0" mass="${foot_mass}" diaginertia="${foot_principal_inertia} ${foot_principal_inertia} ${foot_principal_inertia}"/>
                        <body name="${name}_foot_for_collision" pos="0 0 0">
                            <inertial pos="0 0 0" mass="1e-6" diaginertia="1e-14 1e-14 1e-14"/>
                            <geom class="collision" type="sphere" size="${foot_radius}" pos="0 0 0" euler="0 0 0"/>
                            <site name="${name}_grf_sensor" type="sphere" size="${foot_radius-0.003}" pos="0 0 0"/>
                        </body>
                    </body>
                </body>
                <body name="${name}_calf_rotor" pos="${calf_rotor_offset_x} ${calf_rotor_offset_y*mirror} 0">
                    <inertial pos="${calf_rotor_com_x} ${calf_rotor_com_y} ${calf_rotor_com_z}" mass="${calf_rotor_mass}" fullinertia="${calf_rotor_ixx} ${calf_rotor_iyy} ${calf_rotor_izz} ${calf_rotor_ixy} ${calf_rotor_ixz} ${calf_rotor_iyz}"/>
                    <geom class="visual" type="cylinder" size="${rotor_radius} ${rotor_length/2.0}" pos="0 0 0" euler="${PI/2.0} 0 0" material="green"/>
                </body>
            </body>
            <body name="${name}_thigh_rotor" pos="${thigh_rotor_offset_x} ${thigh_rotor_offset_y*mirror} 0">
                <inertial pos="${thigh_rotor_com_x} ${thigh_rotor_com_y} ${thigh_rotor_com_z}" mass="${thigh_rotor_mass}" fullinertia="${thigh_rotor_ixx} ${thigh_rotor_iyy} ${thigh_rotor_izz} ${thigh_rotor_ixy} ${thigh_rotor_ixz} ${thigh_rotor_iyz}"/>
                <geom class="visual" type="cylinder" size="${rotor_radius} ${rotor_length/2.0}" pos="0 0 0" euler="${PI/2.0} 0 0" material="green"/>
            </body>
        </body>
        <body name="${name}_hip_rotor" pos="${used_hip_rotor_offset_x} ${used_hip_rotor_offset_y} 0">
            <inertial pos="${hip_rotor_com_x} ${hip_rotor_com_y} ${hip_rotor_com_z}" mass="${hip_rotor_mass}" fullinertia="${hip_rotor_ixx} ${hip_rotor_iyy} ${hip_rotor_izz} ${hip_rotor_ixy} ${hip_rotor_ixz} ${hip_rotor_iyz}"/>
            <geom class="visual" type="cylinder" size="${rotor_radius} ${rotor_length/2.0}" pos="0 0 0" euler="0 ${PI/2.0} 0" material="green"/>
        </body>
    </xacro:macro>
</mujoco>
