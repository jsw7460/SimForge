{
    "version": "2.0.0",
    "tasks": [
        // --------------------------- go1_model ----------------------
        {   "label": "build release: go1_model",
            "type": "shell",
            "command": "colcon build --packages-up-to go1_model --cmake-args -DCMAKE_BUILD_TYPE=Release",
            "options": {
                "cwd": "${workspaceFolder}",
            },
            "group": "build"
        },
        {   "label": "gen urdf: stl",
            "type": "shell",
            "command": "source ${workspaceFolder}/install/setup.bash && ros2 run xacro xacro ${XACRO_PATH} MESH_DIR:=${MESH_DIR} MESH_FORMAT:=${MESH_FORMAT} -o ${URDF_STORE_PATH}",
            "options": {
                "cwd": "${workspaceFolder}/install/go1_model/share/go1_model/xacro/urdf",
                "env": {
                    "XACRO_PATH": "robot.xacro",
                    "URDF_STORE_PATH": "${workspaceFolder}/src/go1_ctrl_clean/go1_model_clean/urdf/go1_simplified_stl.urdf",
                    "MESH_DIR": "../meshes/simplified_stl",
                    "MESH_FORMAT": "stl"
                }
            },
            "group": "build"
        },
        {   "label": "gen urdf: obj",
            "type": "shell",
            "command": "source ${workspaceFolder}/install/setup.bash && ros2 run xacro xacro ${XACRO_PATH} MESH_DIR:=${MESH_DIR} MESH_FORMAT:=${MESH_FORMAT} -o ${URDF_STORE_PATH}",
            "options": {
                "cwd": "${workspaceFolder}/install/go1_model/share/go1_model/xacro/urdf",
                "env": {
                    "XACRO_PATH": "robot.xacro",
                    "URDF_STORE_PATH": "${workspaceFolder}/src/go1_ctrl_clean/go1_model_clean/urdf/go1_obj.urdf",
                    "MESH_DIR": "../meshes/obj",
                    "MESH_FORMAT": "obj"
                }
            },
            "group": "build"
        },
        {   "label": "gen urdf: dae",
            "type": "shell",
            "command": "source ${workspaceFolder}/install/setup.bash && ros2 run xacro xacro ${XACRO_PATH} MESH_DIR:=${MESH_DIR} MESH_FORMAT:=${MESH_FORMAT} -o ${URDF_STORE_PATH}",
            "options": {
                "cwd": "${workspaceFolder}/install/go1_model/share/go1_model/xacro/urdf",
                "env": {
                    "XACRO_PATH": "robot.xacro",
                    "URDF_STORE_PATH": "${workspaceFolder}/src/go1_ctrl_clean/go1_model_clean/urdf/go1_dae.urdf",
                    "MESH_DIR": "../meshes/dae",
                    "MESH_FORMAT": "dae"
                }
            },
            "group": "build"
        },
        {   "label": "gen mjcf",
            "type": "shell",
            "command": "source ${workspaceFolder}/install/setup.bash && ros2 run xacro xacro ${XACRO_PATH} MESH_DIR:=${MESH_DIR} -o ${MJCF_STORE_PATH}",
            "options": {
                "cwd": "${workspaceFolder}/install/go1_model/share/go1_model/xacro/mjcf",
                "env": {
                    "XACRO_PATH": "robot.xacro",
                    "MJCF_STORE_PATH": "${workspaceFolder}/src/go1_ctrl_clean/go1_model_clean/mjcf/go1_simplified_stl.xml",
                    "MESH_DIR": "../meshes/simplified_stl",
                }
            },
            "group": "build"
        },
    ]
}